# PatentForge Environment Variables
# Copy this file to .env and fill in values

# Required for Docker deployments — generate with: openssl rand -hex 32
INTERNAL_SERVICE_SECRET=

# Optional — defaults to http://localhost:8080
# ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com

# Optional — Anthropic API key (can also be set in Settings UI)
# ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL (used by backend)
DATABASE_URL=postgresql://patentforge:patentforge@localhost:5432/patentforge

# Service URLs (used by backend)
FEASIBILITY_URL=http://localhost:3001

# Node environment
NODE_ENV=development
